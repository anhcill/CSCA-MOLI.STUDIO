## 📐 KIẾN TRÚC BỔ SUNG CẦN THÊM

### Database Tables Còn Thiếu
```sql
-- 1. Comments
CREATE TABLE comments (
  id SERIAL PRIMARY KEY,
  post_id INT REFERENCES posts(id) ON DELETE CASCADE,
  user_id INT REFERENCES users(id) ON DELETE CASCADE,
  parent_id INT REFERENCES comments(id) ON DELETE CASCADE,
  content TEXT NOT NULL,
  likes_count INT DEFAULT 0,
  is_hidden BOOLEAN DEFAULT FALSE,
  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW()
);

-- 2. Flashcard Progress (SM-2 Algorithm)
CREATE TABLE flashcard_progress (
  id SERIAL PRIMARY KEY,
  user_id INT REFERENCES users(id) ON DELETE CASCADE,
  word_id INT REFERENCES vocabulary_items(id) ON DELETE CASCADE,
  ease_factor FLOAT DEFAULT 2.5,
  interval_days INT DEFAULT 1,
  repetitions INT DEFAULT 0,
  next_review DATE DEFAULT CURRENT_DATE,
  last_reviewed TIMESTAMP,
  UNIQUE(user_id, word_id)
);

-- 3. Bookmarks
CREATE TABLE bookmarks (
  id SERIAL PRIMARY KEY,
  user_id INT REFERENCES users(id),
  material_id INT REFERENCES materials(id),
  created_at TIMESTAMP DEFAULT NOW(),
  UNIQUE(user_id, material_id)
);

-- 4. Admin Activity Logs
CREATE TABLE admin_activity_logs (
  id SERIAL PRIMARY KEY,
  admin_id INT REFERENCES users(id),
  action VARCHAR(100) NOT NULL,    -- 'create_exam', 'ban_user', etc.
  entity_type VARCHAR(50),         -- 'exam', 'user', 'post'
  entity_id INT,
  details JSONB,
  ip_address INET,
  created_at TIMESTAMP DEFAULT NOW()
);

-- 5. Post Reports
CREATE TABLE post_reports (
  id SERIAL PRIMARY KEY,
  post_id INT REFERENCES posts(id),
  reporter_id INT REFERENCES users(id),
  reason TEXT,
  status VARCHAR(20) DEFAULT 'pending',
  created_at TIMESTAMP DEFAULT NOW()
);
```

### API Endpoints Cần Thêm
```
Comments:
  GET    /api/posts/:id/comments
  POST   /api/posts/:id/comments
  DELETE /api/posts/:postId/comments/:commentId
  POST   /api/comments/:id/like

Flashcard:
  GET    /api/vocabulary/flashcard/session
  POST   /api/vocabulary/flashcard/review
  GET    /api/vocabulary/flashcard/stats
  GET    /api/vocabulary/flashcard/streak

User Stats:
  GET    /api/stats/me               — thống kê cá nhân
  GET    /api/stats/me/subjects      — theo môn
  GET    /api/stats/me/weak-topics   — chủ đề yếu
  GET    /api/stats/me/trend         — trend điểm theo tuần

Bookmarks:
  GET    /api/materials/bookmarked
  POST   /api/materials/:id/bookmark
  DELETE /api/materials/:id/bookmark

Admin Enhanced:
  GET    /api/admin/analytics        — chart data
  GET    /api/admin/activity-logs    — activity log
  POST   /api/admin/users/:id/ban
  POST   /api/admin/users/:id/unban
  GET    /api/admin/reports          — post reports
  PATCH  /api/admin/posts/:id/hide
  GET    /api/admin/export/users     — CSV export
```

