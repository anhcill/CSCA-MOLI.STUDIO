# ====================================
# CSCA Backend — Environment Variables
# Copy file này thành .env và điền giá trị thực
# ⚠️  KHÔNG commit file .env lên git!
# ====================================

# ── Database (PostgreSQL) ─────────────────
DATABASE_URL=postgresql://user:password@host:5432/database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=csca_db

# ── JWT Auth ──────────────────────────────
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_min_64_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_64_chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend URL (CORS) ───────────────────
# Development:
FRONTEND_URL=http://localhost:3000
# Production (Railway): https://csca-moli-studio.vercel.app

# ── Google OAuth ──────────────────────────
# Tạo tại: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Brevo Email (Sendinblue) ─────────────────────────────────────────────────
# Đăng ký: https://app.brevo.com → Settings → SMTP & API Keys
# Sender name: CSCA Platform | Sender email: cloudlystudio05@gmail.com
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_SENDER=cloudlystudio05@gmail.com
EMAIL_SENDER_NAME=CSCA Platform

# ── SMTP Email (Gmail App Password) ─────────────────────────────────────────
# ⚠️  DEPRECATED — Đã chuyển sang Brevo (SMTP). Giữ lại để backup.
# Bật 2FA Gmail → Tạo App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password_16_chars

# ── Cloudinary (ảnh & tài liệu PDF) ──────
# Đăng ký miễn phí tại: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Gemini AI ─────────────────────────────
# Lấy API key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── File Upload ───────────────────────────
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,audio/mpeg,audio/wav

# ── MoMo Payment ─────────────────────────
# Đăng ký sandbox/production: https://business.momo.vn/
# Sandbox: https://sandbox.momo.vn
# ⚠️ Khi lên production: thay ENDPOINT + bật IPN_URL (HTTPS bắt buộc)
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_PARTNER_CODE=MOMOTEST
MOMO_ACCESS_KEY=F8BBD362
MOMO_SECRET_KEY=xxxx
MOMO_REDIRECT_URL=https://your-domain.com/checkout/success
MOMO_IPN_URL=https://your-domain.com/api/payments/momo-webhook

# ── VNPay Payment ─────────────────────────
# Đăng ký: https://sandbox.vnpayment.vn/apis
# Production: https://vnpayment.vn
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=TESTVNPAY
VNPAY_HASH_SECRET=xxxx
VNPAY_RETURN_URL=https://your-domain.com/checkout/success

# ── Debug (tuỳ chọn) ──────────────────────
# Bật query logging khi cần debug
# DEBUG_QUERIES=1

