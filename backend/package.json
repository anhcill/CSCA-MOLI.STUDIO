{
  "name": "csca-backend",
  "version": "1.0.0",
  "description": "Backend API for CSCA - China Scholarship Council Assessment Platform",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --watchAll --verbose",
    "db:migrate": "node src/scripts/migrate.js",
    "db:seed": "node src/scripts/seed.js",
    "db:rbac": "node scripts/setup_rbac.js",
    "db:rbac:migrate": "node scripts/setup_rbac.js --migrate-only",
    "db:rbac:seed": "node scripts/setup_rbac.js --seed-only",
    "db:forum:migrate": "node scripts/apply_migration.js ../../database/migrations/006_add_forum_moderation_fields.sql",
    "db:roadmap:migrate": "node scripts/apply_migration.js ../../database/migrations/007_create_roadmap_milestones.sql",
    "db:exam-schedule:migrate": "node scripts/apply_migration.js ../../database/migrations/008_create_exam_schedule_logs.sql",
    "test:forum-rbac": "node test_forum_rbac.js",
    "test:roadmap-rbac": "node test_roadmap_rbac.js",
    "test:exam-schedule-logs": "node test_exam_schedule_logs.js"
  },
  "keywords": [
    "csca",
    "exam",
    "education",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.15.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.9.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.13",
    "openai": "^4.104.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
